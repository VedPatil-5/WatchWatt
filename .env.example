# ─────────────────────────────────────────────────────────────
#  Smart Energy-Saving Human Detection System — .env
#  COPY THIS FILE TO: smart-energy-system/.env
#  NEVER commit the real .env to git!
# ─────────────────────────────────────────────────────────────

# ── MongoDB ───────────────────────────────────────────────────
# Get a free cluster at https://cloud.mongodb.com
# Replace <username>, <password>, <cluster>, <dbname> with yours
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority

# ── Session Secret ────────────────────────────────────────────
# Generate a strong random string (e.g. run: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
SESSION_SECRET=replace_with_a_long_random_string_here

# ── WhatsApp Business API ─────────────────────────────────────
# From https://developers.facebook.com → Your App → WhatsApp → API Setup
WHATSAPP_TOKEN=your_whatsapp_access_token_here
WHATSAPP_PHONE_ID=your_whatsapp_phone_number_id_here

# ── Flask Detection Server ────────────────────────────────────
# If running locally, keep as is. If using ngrok for Flask, replace with ngrok URL
FLASK_STREAM_URL=http://localhost:5000/detection_feed

# ── Frontend URL (for CORS) ───────────────────────────────────
# If deploying with ngrok or Railway, put your public URL here
FRONTEND_URL=http://localhost:3000

# ── Node Environment ──────────────────────────────────────────
# Change to "production" when deploying live
NODE_ENV=development

# ── Port ─────────────────────────────────────────────────────
PORT=3000
